server {
    listen 80;
    listen [::]:80;

    server_name {{ pihole_hostname }};

    access_log /var/log/nginx/access.log;
    error_log /var/log/nginx/error.log;

    location = / {
        return 301 /admin/;
    }

    location /admin/ {
        proxy_pass http://127.0.0.1:{{ pihole_port }}/admin/;
    }
    location /api/ {
        proxy_pass http://127.0.0.1:{{ pihole_port }}/api/;
    }
}
